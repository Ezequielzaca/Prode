<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Prode Mundial 2026</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700;800&display=swap" rel="stylesheet">

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family:'Montserrat',sans-serif;
    }

    body{
      background: linear-gradient(180deg,#020617,#071226,#0f172a);
      color:white;
      min-height:100vh;
      overflow-x:hidden;
    }

    /* HEADER */

    .header{
      width:100%;
      padding:25px;
      text-align:center;
      border-bottom:1px solid rgba(255,255,255,0.08);
      background:rgba(0,0,0,0.25);
      backdrop-filter:blur(10px);
      position:sticky;
      top:0;
      z-index:100;
    }

    .header h1{
      font-size:32px;
      font-weight:800;
      letter-spacing:2px;
      color:#7dd3fc;
    }

    .header p{
      margin-top:8px;
      color:#cbd5e1;
      font-size:14px;
    }

    /* CONTAINER */

    .container{
      width:100%;
      max-width:1200px;
      margin:auto;
      padding:30px 20px 120px;
    }

    /* PARTIDOS */

    .section-title{
      font-size:28px;
      font-weight:700;
      margin-bottom:25px;
      color:#facc15;
    }

    .match-card{
      background:rgba(15,23,42,0.9);
      border:1px solid rgba(125,211,252,0.15);
      border-radius:20px;
      padding:25px;
      margin-bottom:25px;
      box-shadow:0 0 20px rgba(0,0,0,0.3);
      transition:0.3s;
    }

    .match-card:hover{
      transform:translateY(-4px);
      border-color:#38bdf8;
    }

    .match-top{
      display:flex;
      justify-content:space-between;
      align-items:center;
      margin-bottom:20px;
      flex-wrap:wrap;
      gap:10px;
    }

    .group{
      background:#0ea5e9;
      color:#fff;
      padding:8px 14px;
      border-radius:12px;
      font-size:13px;
      font-weight:700;
    }

    .date{
      color:#cbd5e1;
      font-size:14px;
    }

    .teams{
      display:flex;
      justify-content:center;
      align-items:center;
      gap:20px;
      margin:25px 0;
      flex-wrap:wrap;
    }

    .team{
      text-align:center;
      width:180px;
    }

    .flag{
      font-size:55px;
      margin-bottom:10px;
    }

    .team-name{
      font-size:20px;
      font-weight:700;
    }

    .vs{
      font-size:30px;
      font-weight:800;
      color:#facc15;
    }

    .prediction{
      display:flex;
      justify-content:center;
      gap:20px;
      margin-top:25px;
      flex-wrap:wrap;
    }

    .prediction input{
      width:80px;
      height:60px;
      border:none;
      border-radius:15px;
      background:#0f172a;
      color:white;
      font-size:28px;
      text-align:center;
      border:2px solid #1e293b;
      transition:0.3s;
    }

    .prediction input:focus{
      outline:none;
      border-color:#38bdf8;
      box-shadow:0 0 10px rgba(56,189,248,0.4);
    }

    .save-btn{
      margin-top:25px;
      width:100%;
      padding:15px;
      border:none;
      border-radius:15px;
      background:linear-gradient(90deg,#0ea5e9,#2563eb);
      color:white;
      font-size:16px;
      font-weight:700;
      cursor:pointer;
      transition:0.3s;
    }

    .save-btn:hover{
      opacity:0.9;
      transform:scale(1.01);
    }

    /* APUESTAS */

    .bettors{
      margin-top:25px;
      border-top:1px solid rgba(255,255,255,0.08);
      padding-top:20px;
    }

    .bettors h4{
      margin-bottom:12px;
      color:#7dd3fc;
    }

    .bettor-list{
      display:flex;
      flex-wrap:wrap;
      gap:10px;
    }

    .bettor{
      background:#111827;
      border:1px solid rgba(255,255,255,0.08);
      padding:10px 14px;
      border-radius:12px;
      font-size:14px;
      color:#e2e8f0;
    }

    /* NAVIGATION */

    .bottom-nav{
      position:fixed;
      bottom:0;
      width:100%;
      background:rgba(2,6,23,0.95);
      backdrop-filter:blur(10px);
      border-top:1px solid rgba(255,255,255,0.08);
      display:flex;
      justify-content:space-around;
      align-items:center;
      padding:15px 10px;
      z-index:999;
    }

    .nav-btn{
      display:flex;
      flex-direction:column;
      align-items:center;
      gap:6px;
      color:#94a3b8;
      text-decoration:none;
      font-size:13px;
      transition:0.3s;
    }

    .nav-btn.active{
      color:#38bdf8;
    }

    .nav-icon{
      font-size:24px;
    }

    /* MOBILE */

    @media(max-width:768px){

      .header h1{
        font-size:24px;
      }

      .team{
        width:120px;
      }

      .team-name{
        font-size:16px;
      }

      .flag{
        font-size:42px;
      }

      .vs{
        font-size:24px;
      }

      .prediction input{
        width:70px;
        height:55px;
      }
    }
  </style>
</head>

<body>

  <!-- HEADER -->

  <div class="header">
    <h1>⚽ PRODE MUNDIAL 2026</h1>
    <p>Predicciones • Ranking • Eliminatorias • Campeón</p>
  </div>

  <!-- MAIN -->

  <div class="container">

    <h2 class="section-title">Próximos Partidos</h2>

    <!-- PARTIDO -->

    <div class="match-card">

      <div class="match-top">
        <div class="group">GRUPO A</div>
        <div class="date">11 Junio • 16:00 hs</div>
      </div>

      <div class="teams">

        <div class="team">
          <div class="flag">🇦🇷</div>
          <div class="team-name">Argentina</div>
        </div>

        <div class="vs">VS</div>

        <div class="team">
          <div class="flag">🇯🇵</div>
          <div class="team-name">Japón</div>
        </div>

      </div>

      <div class="prediction">
        <input type="number" min="0" placeholder="0">
        <input type="number" min="0" placeholder="0">
      </div>

      <button class="save-btn">
        Guardar Pronóstico
      </button>

      <div class="bettors">
        <h4>Ya pronosticaron:</h4>

        <div class="bettor-list">
          <div class="bettor">✓ Juan Pérez</div>
          <div class="bettor">✓ Lucas Gómez</div>
          <div class="bettor">✓ Martín Ruiz</div>
        </div>
      </div>

    </div>

    <!-- PARTIDO -->

    <div class="match-card">

      <div class="match-top">
        <div class="group">GRUPO B</div>
        <div class="date">12 Junio • 20:00 hs</div>
      </div>

      <div class="teams">

        <div class="team">
          <div class="flag">🇧🇷</div>
          <div class="team-name">Brasil</div>
        </div>

        <div class="vs">VS</div>

        <div class="team">
          <div class="flag">🇩🇪</div>
          <div class="team-name">Alemania</div>
        </div>

      </div>

      <div class="prediction">
        <input type="number" min="0" placeholder="0">
        <input type="number" min="0" placeholder="0">
      </div>

      <button class="save-btn">
        Guardar Pronóstico
      </button>

      <div class="bettors">
        <h4>Ya pronosticaron:</h4>

        <div class="bettor-list">
          <div class="bettor">✓ Ezequiel</div>
          <div class="bettor">✓ Franco</div>
        </div>
      </div>

    </div>

  </div>

  <!-- NAVBAR -->

  <div class="bottom-nav">

    <a href="#" class="nav-btn">
      <div class="nav-icon">🏆</div>
      <span>Ranking</span>
    </a>

    <a href="#" class="nav-btn active">
      <div class="nav-icon">⚽</div>
      <span>Inicio</span>
    </a>

    <a href="#" class="nav-btn">
      <div class="nav-icon">🌎</div>
      <span>Mundial</span>
    </a>

  </div>

</body>
</html>
