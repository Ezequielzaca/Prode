// ════════════════════════════════════════
//  PARSE SCORE
// ════════════════════════════════════════
function parseScore(sc){
  var sets=(sc||'').trim().split(/\s+/),s1=0,s2=0,g1=0,g2=0;
  sets.forEach(function(s,idx){
    var p=s.split('-');if(p.length!==2)return;
    var a=parseInt(p[0])||0,b=parseInt(p[1])||0;
    if(idx===2){if(a>b){s1++;g1++}else if(b>a){s2++;g2++}}
    else{g1+=a;g2+=b;if(a>b)s1++;else if(b>a)s2++}
  });
  return{s1:s1,s2:s2,g1:g1,g2:g2};
}

