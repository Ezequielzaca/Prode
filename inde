  sel.innerHTML='<option value="">Ganador...</option><option value="1">'+m.p1+'</option><option value="2">'+m.p2+'</option>';
  sel.value=String(m.winner);
  document.getElementById('eRSc').value=m.score;document.getElementById('eRDt').value=m.fecha;
  document.getElementById('mEditR').classList.add('show');
}
function saveEditR(){
  if(!editRId)return;
  var score=document.getElementById('eRSc').value.trim(),winner=parseInt(document.getElementById('eRW').value),fecha=document.getElementById('eRDt').value;
  if(!score||!winner||!fecha){toast('⚠ Completá todos los campos');return}
  var updated=results.map(function(r){return r.id!==editRId?r:Object.assign({},r,{score:score,winner:winner,fecha:fecha})});
  db.ref('resultados').set(updated,function(err){if(!err){clMod('mEditR');toast('✓ Resultado actualizado');editRId=null}});
}

// ════════════════════════════════════════
//  PAREJAS
// ════════════════════════════════════════
function rJugInfo(){
  var el=document.getElementById('jugInfo');
  if(!parts.length){el.style.display='none';return}
  var totals={};CATS.forEach(function(c){totals[c]=0});
  parts.forEach(function(p){if(totals[p.cat]!==undefined)totals[p.cat]++});
  var cats=CATS.filter(function(c){return totals[c]>0});
  el.style.display='block';
  el.innerHTML='<div class="info-strip">'+
    '<div class="info-box"><div class="iv">'+parts.length+'</div><div class="il">Parejas</div></div>'+
    cats.slice(0,3).map(function(c){return'<div class="info-box"><div class="iv" style="color:var(--'+CS[c]+')">'+totals[c]+'</div><div class="il" style="color:var(--'+CS[c]+')">'+CL[c]+'</div></div>'}).join('')+
  '</div>';
}
function rJugList(){
  var el=document.getElementById('jugList');el.innerHTML='';
  if(!parts.length){el.innerHTML='<div class="es"><div class="es-i">👥</div><div class="es-t">Sin parejas aún</div><div class="es-s">Usá el formulario de arriba</div></div>';return}
  var sorted=parts.slice().sort(function(a,b){return(a.cat+a.nombre+a.apellido).localeCompare(b.cat+b.nombre+b.apellido)});
  var cc='';
  sorted.forEach(function(p){
    if(p.cat!==cc){cc=p.cat;el.innerHTML+='<div class="slbl" style="margin-top:14px">'+CL[p.cat]+'</div>'}
    el.innerHTML+='<div class="pc">'+
      '<div class="pav">'+(p.nombre[0]||'').toUpperCase()+(p.apellido[0]||'').toUpperCase()+'</div>'+
      '<span class="pnm">'+pnm(p)+'</span>'+
      '<span class="lb l-'+CS[p.cat]+'" style="font-size:.5rem;margin-right:4px">'+(p.grupo?'G'+p.grupo:'')+'</span>'+
      '<button class="pico edit" onclick="openEditJ(\''+p.id+'\')" title="Editar">✏</button>'+
      '<button class="pico del" onclick="delJug(\''+p.id+'\')" title="Eliminar" style="margin-left:4px">✕</button>'+
    '</div>';
  });
}
function _guardar(n,a,cat,grp,clearAll){
  if(!n||!a||!cat){toast('⚠ Completá los dos apellidos y la categoría');return}
  db.ref('parejas').set(parts.concat([{id:uid(),nombre:n,apellido:a,cat:cat,grupo:grp||''}]),function(err){
    if(err){toast('⚠ Error al guardar');return}
    document.getElementById('jN').value='';document.getElementById('jA').value='';
    if(clearAll){document.getElementById('jC').value='';document.getElementById('jG').value=''}
    toast('✓ '+n+' / '+a+' agregada');
  });
}
function addJug(){_guardar(document.getElementById('jN').value.trim(),document.getElementById('jA').value.trim(),document.getElementById('jC').value,document.getElementById('jG').value,true)}
function quickAddJug(){_guardar(document.getElementById('jN').value.trim(),document.getElementById('jA').value.trim(),document.getElementById('jC').value,document.getElementById('jG').value,false)}
function delJug(pid){
  var p=parts.find(function(x){return x.id===pid});if(!p)return;
  if(!confirm('¿Eliminar la pareja '+pnm(p)+'?\nTambién se eliminarán sus resultados.'))return;
  db.ref('parejas').set(parts.filter(function(x){return x.id!==pid}));
  db.ref('resultados').set(results.filter(function(r){return r.p1id!==pid&&r.p2id!==pid}),function(err){if(!err)toast('Pareja eliminada')});
}
function openEditJ(pid){
  editJId=pid;var p=parts.find(function(x){return x.id===pid});if(!p)return;
  document.getElementById('ejN').value=p.nombre;document.getElementById('ejA').value=p.apellido;
  document.getElementById('ejC').value=p.cat;document.getElementById('ejG').value=p.grupo||'';
  document.getElementById('mEditJ').classList.add('show');
}
function saveEditJ(){
  if(!editJId)return;
  var p=parts.find(function(x){return x.id===editJId});if(!p)return;
  var n=document.getElementById('ejN').value.trim(),a=document.getElementById('ejA').value.trim();
  var c=document.getElementById('ejC').value,g=document.getElementById('ejG').value;
  if(!n||!a||!c){toast('⚠ Completá todos los campos');return}
  var newNm=n+' / '+a;
  db.ref('parejas').set(parts.map(function(x){return x.id!==editJId?x:Object.assign({},x,{nombre:n,apellido:a,cat:c,grupo:g||''})}));
  db.ref('resultados').set(results.map(function(r){
    if(r.p1id===editJId)return Object.assign({},r,{p1:newNm});
    if(r.p2id===editJId)return Object.assign({},r,{p2:newNm});
    return r;
  }),function(err){if(!err){clMod('mEditJ');toast('✓ Pareja actualizada');editJId=null}});
}

// ════════════════════════════════════════
//  FIFA CARD
// ════════════════════════════════════════
function openCard(i){
  var s=window._pd[i];if(!s)return;
  function gr(p,r){if(p===1)return'linear-gradient(145deg,#064e3b,#047857)';if(p===2)return'linear-gradient(145deg,#78350f,#a16207)';if(p===3)return'linear-gradient(145deg,#7c2d12,#c2410c)';return r>=50?'linear-gradient(145deg,#1e3a5f,#2563eb)':'linear-gradient(145deg,#450a0a,#991b1b)'}
  function ac(p,r){if(p===1)return'var(--acc)';if(p===2)return'var(--oro)';if(p===3)return'var(--bro)';return r>=50?'#60a5fa':'#f87171'}
  var g=gr(s.pos,s.rat),a=ac(s.pos,s.rat);
  var pl=s.pos===1?'1ER PUESTO':s.pos===2?'2DO PUESTO':s.pos===3?'3ER PUESTO':s.pos+'° PUESTO';
  var wp=s.pj>0?Math.round(s.pg/s.pj*100):0;
  var sp=s.pj>0?Math.round(s.sg/Math.max(s.sg+s.sp,1)*100):0;
  var gp=s.pj>0?Math.round(s.gg/Math.max(s.gg+s.gp,1)*100):0;
  document.getElementById('fcCard').innerHTML=
    '<div class="fc-top" style="background:'+g+';color:#fff">'+
    '<button class="fc-x" onclick="clCard()">✕</button>'+
    '<div class="fc-r" style="color:'+a+'">'+s.rat+'</div>'+
    '<div class="fc-pos" style="color:'+a+'">'+pl+'</div>'+
    '<div class="fc-nm">'+s.nm+'</div>'+
    '<div class="fc-cat">'+CL[s.cat]+(s.grp?' · Grupo '+s.grp:'')+'</div></div>'+
    '<div class="fc-div"></div>'+
    '<div class="fc-sts" style="background:'+g+';color:#fff">'+
    '<div class="fst"><span class="fst-l">PJ</span><span class="fst-v">'+s.pj+'</span></div>'+
    '<div class="fst"><span class="fst-l">Pts</span><span class="fst-v" style="color:'+(s.pts>=0?a:'#f87171')+'">'+(s.pts>0?'+':'')+s.pts+'</span></div>'+
    '<div class="fst"><span class="fst-l">PG</span><span class="fst-v" style="color:var(--acc)">'+s.pg+'</span></div>'+
    '<div class="fst"><span class="fst-l">PP</span><span class="fst-v" style="color:#f87171">'+s.pp+'</span></div>'+
    '<div class="fst fst-f"><span class="fst-l">% Victorias</span><span class="fst-v">'+wp+'%</span></div>'+
    '<div class="fst fst-f" style="flex-direction:column;align-items:stretch"><div style="display:flex;justify-content:space-between"><span class="fst-l">Sets '+s.sg+'G / '+s.sp+'P</span><span class="fst-v" style="color:'+(s.sd>=0?a:'#f87171')+'">'+(s.sd>0?'+':'')+s.sd+'</span></div><div class="fbar"><div class="fbar-f" style="width:'+sp+'%;background:'+a+'"></div></div></div>'+
    '<div class="fst fst-f" style="flex-direction:column;align-items:stretch"><div style="display:flex;justify-content:space-between"><span class="fst-l">Games '+s.gg+'G / '+s.gp+'P</span><span class="fst-v" style="color:'+(s.gd>=0?a:'#f87171')+'">'+(s.gd>0?'+':'')+s.gd+'</span></div><div class="fbar"><div class="fbar-f" style="width:'+gp+'%;background:'+a+'"></div></div></div>'+
    '</div>';
  document.getElementById('cardBg').classList.add('show');
}
</script>
