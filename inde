<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no"/>
<title>Tenis ATR 2026</title>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
:root{--bg:#0a0e17;--card:#1a2236;--card-h:#1f2a42;--acc:#34d399;--acc-d:rgba(52,211,153,.15);--acc-g:rgba(52,211,153,.3);--t1:#f1f5f9;--t2:#94a3b8;--tm:#64748b;--brd:rgba(255,255,255,.06);--r:16px;--rs:10px;--nav-h:72px;--sig:#a855f7;--oro:#fbbf24;--pla:#cbd5e1;--bro:#f59e0b;--mad:#a3763d;--muj:#f472b6}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
body{font-family:'Outfit',sans-serif;background:var(--bg);color:var(--t1);min-height:100dvh;overflow-x:hidden;padding-bottom:calc(var(--nav-h)+40px)}
.hdr{position:sticky;top:0;z-index:100;backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);background:rgba(10,14,23,.85);border-bottom:1px solid var(--brd);padding:16px 20px}
.hdr-in{max-width:500px;margin:0 auto;display:flex;align-items:center;justify-content:space-between}
.brand{display:flex;align-items:center;gap:12px}
.brand-ic{width:42px;height:42px;background:linear-gradient(135deg,var(--acc),#059669);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:20px;box-shadow:0 4px 15px var(--acc-g)}
.brand-nm{font-weight:800;font-size:1.15rem;background:linear-gradient(135deg,var(--acc),#6ee7b7);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.brand-sb{font-size:.7rem;color:var(--tm);font-weight:500;letter-spacing:2px;text-transform:uppercase}
.hdr-yr{font-family:'Space Mono',monospace;font-size:.85rem;color:var(--acc);background:var(--acc-d);padding:6px 14px;border-radius:20px;font-weight:700}
.main{max-width:500px;margin:0 auto;padding:20px 16px}
.slbl{font-size:.7rem;font-weight:700;color:var(--tm);letter-spacing:2.5px;text-transform:uppercase;margin-bottom:12px;padding-left:4px}
.page{display:none}.page.active{display:block;animation:fu .4s ease both;padding-bottom:20px}
@keyframes fu{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
.loading{position:fixed;inset:0;background:var(--bg);z-index:500;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px}
.loading-spin{width:44px;height:44px;border:3px solid var(--brd);border-top-color:var(--acc);border-radius:50%;animation:spin .8s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.loading-txt{font-size:.85rem;color:var(--tm);font-weight:500}
.sync{display:inline-flex;align-items:center;gap:5px;font-size:.65rem;color:var(--tm);font-weight:500}
.sync-dot{width:7px;height:7px;border-radius:50%;background:var(--acc);animation:pulse 2s infinite;flex-shrink:0}
.sync-dot.off{background:#f87171;animation:none}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
.ctabs{display:flex;gap:6px;flex-wrap:nowrap;margin-bottom:18px;overflow-x:auto;-webkit-overflow-scrolling:touch;padding-bottom:4px;justify-content:center}
.ctabs::-webkit-scrollbar{display:none}
.ct{padding:6px 14px;border-radius:20px;font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;cursor:pointer;border:1.5px solid transparent;transition:.25s;background:var(--card);color:var(--tm);flex-shrink:0}
.ct:hover{border-color:rgba(255,255,255,.15)}
.ct.a-sig{background:rgba(168,85,247,.2);color:var(--sig);border-color:var(--sig)}
.ct.a-oro{background:rgba(251,191,36,.2);color:var(--oro);border-color:var(--oro)}
.ct.a-pla{background:rgba(203,213,225,.2);color:var(--pla);border-color:var(--pla)}
.ct.a-bro{background:rgba(245,158,11,.2);color:var(--bro);border-color:var(--bro)}
.ct.a-mad{background:rgba(163,118,61,.2);color:var(--mad);border-color:var(--mad)}
.ct.a-muj{background:rgba(244,114,182,.2);color:var(--muj);border-color:var(--muj)}
.lb{font-size:.65rem;font-weight:700;padding:2px 8px;border-radius:6px;text-transform:uppercase;letter-spacing:.5px}
.l-sig{background:rgba(168,85,247,.2);color:var(--sig)}.l-oro{background:rgba(251,191,36,.2);color:var(--oro)}.l-pla{background:rgba(203,213,225,.2);color:var(--pla)}.l-bro{background:rgba(245,158,11,.2);color:var(--bro)}.l-mad{background:rgba(163,118,61,.2);color:var(--mad)}.l-muj{background:rgba(244,114,182,.2);color:var(--muj)}
.es{text-align:center;padding:50px 20px;color:var(--tm)}.es-i{font-size:3rem;margin-bottom:12px;opacity:.4}.es-t{font-size:.9rem;font-weight:500}.es-s{font-size:.78rem;margin-top:4px;opacity:.7}
.pw{overflow-x:auto;-webkit-overflow-scrolling:touch;border-radius:var(--rs);margin-bottom:16px}
.pt{border-collapse:collapse;font-size:.7rem;width:100%}
.pt th,.pt td{border:1px solid var(--brd);padding:8px 5px;text-align:center;white-space:nowrap}
.pt th{background:var(--card);color:var(--t2);font-weight:600;font-size:.55rem;text-transform:uppercase;letter-spacing:.3px}
.pt td{background:var(--bg)}
.pt .pn{text-align:left;font-weight:600;background:var(--card);position:sticky;left:0;z-index:2;min-width:90px;max-width:130px;overflow:hidden;text-overflow:ellipsis;font-size:.68rem;cursor:pointer}
.pt .pn:hover{opacity:.8}
.pt .pp{font-family:'Space Mono',monospace;font-weight:800;background:var(--card);color:var(--tm);width:24px}
.pt .pv{font-weight:800;font-size:.82rem}
.p1c{color:var(--acc)!important}.p2c{color:var(--oro)!important}.p3c{color:var(--bro)!important}
.pos{color:var(--acc)}.neg{color:#f87171}.zer{color:var(--tm)}
.sep{border-left:2px solid rgba(255,255,255,.1)}
.gw{overflow-x:auto;-webkit-overflow-scrolling:touch;margin-bottom:20px}
.gt{border-collapse:collapse;font-size:.65rem}
.gt th,.gt td{border:1px solid var(--brd);padding:6px 4px;text-align:center;white-space:nowrap}
.gt th{background:var(--card);color:var(--t2);font-weight:600;font-size:.6rem}
.gt td{background:var(--bg);color:var(--t1)}
.gt .self{background:var(--card);color:var(--tm)}
.gt .win{background:rgba(52,211,153,.15);color:var(--acc);font-weight:700}
.gt .loss{background:rgba(239,68,68,.1);color:#f87171;font-weight:600}
.gt .rn{text-align:left;font-weight:600;background:var(--card);min-width:90px;max-width:130px;position:sticky;left:0;z-index:2;font-size:.65rem;overflow:hidden;text-overflow:ellipsis}
.gt .cn{font-family:'Space Mono',monospace;font-weight:700;color:var(--tm);background:var(--card);width:24px;font-size:.65rem}
.rc{background:var(--card);border:1px solid var(--brd);border-radius:var(--r);padding:16px 18px;margin-bottom:10px}
.rd{font-family:'Space Mono',monospace;font-size:.7rem;color:var(--tm);margin-bottom:10px}
.rm{display:flex;align-items:center;gap:8px;margin-bottom:8px;flex-wrap:wrap}.rm:last-child{margin-bottom:0}
.rp{flex:1;font-weight:500;font-size:.82rem;min-width:0;line-height:1.5}
.rsc{font-family:'Space Mono',monospace;font-weight:700;font-size:.82rem;color:var(--acc);flex-shrink:0}
.rw{color:var(--acc);font-weight:700}
.af{background:var(--card);border:1px solid var(--brd);border-radius:var(--r);padding:18px;margin-bottom:20px}
.af-t{font-weight:700;font-size:.95rem;margin-bottom:14px}
.fr{display:flex;gap:8px;margin-bottom:10px}
.fi{flex:1;padding:10px 14px;border-radius:var(--rs);border:1px solid var(--brd);background:var(--bg);color:var(--t1);font-family:'Outfit',sans-serif;font-size:.88rem;outline:0;transition:border-color .2s}
.fi:focus{border-color:var(--acc)}.fi::placeholder{color:var(--tm)}
.fs{padding:10px 14px;border-radius:var(--rs);border:1px solid var(--brd);background:var(--bg);color:var(--t1);font-family:'Outfit',sans-serif;font-size:.88rem;outline:0;cursor:pointer;flex:1}
.fs:focus{border-color:var(--acc)}
.fb{width:100%;padding:12px;border-radius:var(--rs);border:0;background:linear-gradient(135deg,var(--acc),#059669);color:var(--bg);font-family:'Outfit',sans-serif;font-size:.9rem;font-weight:700;cursor:pointer;transition:.25s;letter-spacing:.5px}
.fb:hover{transform:translateY(-1px);box-shadow:0 4px 16px var(--acc-g)}
.fb:disabled{opacity:.5;cursor:default;transform:none;box-shadow:none}
.pc{background:var(--card);border:1px solid var(--brd);border-radius:var(--rs);padding:12px 16px;margin-bottom:6px;display:flex;align-items:center;gap:12px}
.pav{width:36px;height:36px;border-radius:50%;background:var(--acc-d);color:var(--acc);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.72rem;flex-shrink:0}
.pnm{font-weight:500;font-size:.88rem;flex:1}
.pico{width:30px;height:30px;border-radius:8px;border:1px solid var(--brd);background:0;color:var(--tm);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:.8rem;flex-shrink:0;transition:.2s}
.pico.edit:hover{background:rgba(52,211,153,.15);color:var(--acc);border-color:var(--acc)}
.pico.del:hover{background:rgba(239,68,68,.15);color:#ef4444;border-color:#ef4444}
.fab{position:fixed;bottom:calc(var(--nav-h)+16px);right:16px;width:52px;height:52px;border-radius:16px;background:linear-gradient(135deg,var(--acc),#059669);border:0;color:var(--bg);font-size:1.5rem;font-weight:700;cursor:pointer;display:none;align-items:center;justify-content:center;box-shadow:0 4px 20px var(--acc-g);z-index:150;transition:.3s}
.fab:hover{transform:scale(1.1)}.fab.show{display:flex}
.mbg{position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:300;display:none;align-items:flex-end;justify-content:center;backdrop-filter:blur(4px)}.mbg.show{display:flex}
.mdl{background:#111827;border-radius:var(--r) var(--r) 0 0;width:100%;max-width:500px;max-height:88vh;overflow-y:auto;padding:24px 20px 30px;animation:su .3s ease}
@keyframes su{from{transform:translateY(100%)}to{transform:translateY(0)}}
.mh{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px}
.mt{font-weight:700;font-size:1.1rem}
.mx{width:34px;height:34px;border-radius:10px;border:1px solid var(--brd);background:0;color:var(--t2);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:1rem}
.mx:hover{background:rgba(239,68,68,.15);color:#ef4444}
.cbg{position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:350;display:none;align-items:center;justify-content:center;backdrop-filter:blur(6px)}.cbg.show{display:flex}
.fc{width:290px;border-radius:20px;overflow:hidden;animation:ci .4s cubic-bezier(.16,1,.3,1) both}
@keyframes ci{from{opacity:0;transform:scale(.8) translateY(30px)}to{opacity:1;transform:scale(1) translateY(0)}}
.fc-top{padding:28px 20px 18px;text-align:center;position:relative}
.fc-x{position:absolute;top:12px;right:12px;width:30px;height:30px;border-radius:50%;border:1px solid rgba(255,255,255,.2);background:rgba(0,0,0,.3);color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:.85rem;z-index:2}
.fc-r{font-family:'Space Mono',monospace;font-size:3.5rem;font-weight:800;line-height:1;margin-bottom:2px}
.fc-pos{font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:2px;opacity:.8;margin-bottom:8px}
.fc-nm{font-size:1.05rem;font-weight:800;letter-spacing:-.5px;margin-bottom:2px}
.fc-cat{font-size:.65rem;font-weight:600;text-transform:uppercase;letter-spacing:1.5px;opacity:.7}
.fc-div{height:1px;background:rgba(255,255,255,.15);margin:0 20px}
.fc-sts{padding:16px 20px 22px;display:grid;grid-template-columns:1fr 1fr;gap:10px}
.fst{display:flex;align-items:center;justify-content:space-between;padding:6px 10px;border-radius:8px;background:rgba(255,255,255,.06)}
.fst-l{font-size:.6rem;font-weight:600;text-transform:uppercase;letter-spacing:.5px;opacity:.6}
.fst-v{font-family:'Space Mono',monospace;font-weight:800;font-size:.85rem}
.fst-f{grid-column:1/-1}
.fbar{height:4px;border-radius:2px;background:rgba(255,255,255,.1);margin-top:6px;overflow:hidden}
.fbar-f{height:100%;border-radius:2px;transition:width .6s ease}
.bnav{position:fixed;bottom:0;left:0;right:0;height:var(--nav-h);background:rgba(17,24,39,.92);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);border-top:1px solid var(--brd);display:flex;align-items:center;justify-content:center;z-index:200;padding-bottom:env(safe-area-inset-bottom,0)}
.nits{display:flex;align-items:center;gap:4px;max-width:500px;width:100%;justify-content:space-around;padding:0 6px}
.ni{display:flex;flex-direction:column;align-items:center;gap:3px;padding:6px 10px;border-radius:14px;cursor:pointer;transition:.25s;color:var(--tm);background:0;border:0;font-family:'Outfit',sans-serif}
.ni:hover{color:var(--t2)}.ni.active{color:var(--acc);background:var(--acc-d)}
.ni svg{width:22px;height:22px}
.nl{font-size:.55rem;font-weight:600;letter-spacing:.5px;text-transform:uppercase}
.nih .niw{width:48px;height:48px;border-radius:15px;background:linear-gradient(135deg,var(--acc),#059669);display:flex;align-items:center;justify-content:center;box-shadow:0 4px 20px var(--acc-g);transition:.3s;margin-top:-12px}
.nih:hover .niw{transform:scale(1.08)}.nih svg{width:24px;height:24px;color:var(--bg)}
.toast{position:fixed;bottom:90px;left:50%;transform:translateX(-50%);background:var(--acc);color:var(--bg);padding:10px 20px;border-radius:12px;font-weight:600;font-size:.85rem;z-index:400;opacity:0;transition:opacity .3s;pointer-events:none;box-shadow:0 4px 20px var(--acc-g);white-space:nowrap}.toast.show{opacity:1}
.abtn{width:30px;height:30px;border-radius:8px;cursor:pointer;display:inline-flex;align-items:center;justify-content:center;font-size:.75rem;flex-shrink:0;transition:.2s;border:1px solid}
.abtn.edit{border-color:rgba(52,211,153,.3);background:rgba(52,211,153,.1);color:var(--acc)}
.abtn.edit:hover{background:rgba(52,211,153,.25);border-color:var(--acc)}
.abtn.del{border-color:rgba(239,68,68,.3);background:rgba(239,68,68,.1);color:#f87171}
.abtn.del:hover{background:rgba(239,68,68,.25);border-color:#ef4444}
.info-strip{display:flex;gap:10px;margin-bottom:16px}
.info-box{flex:1;background:var(--card);border:1px solid var(--brd);border-radius:var(--rs);padding:12px;text-align:center}
.info-box .iv{font-size:1.3rem;font-weight:800;color:var(--acc);font-family:'Space Mono',monospace}
.info-box .il{font-size:.6rem;color:var(--tm);font-weight:600;text-transform:uppercase;letter-spacing:1px;margin-top:2px}
</style>
</head>
<body>

<div class="loading" id="loadScr">
  <div style="width:56px;height:56px;background:linear-gradient(135deg,var(--acc),#059669);border-radius:16px;display:flex;align-items:center;justify-content:center;font-size:28px;box-shadow:0 4px 20px var(--acc-g);margin-bottom:8px">🎾</div>
  <div class="loading-spin"></div>
  <div class="loading-txt">Conectando...</div>
</div>

<header class="hdr"><div class="hdr-in">
  <div class="brand">
    <div class="brand-ic">🎾</div>
    <div><div class="brand-nm">Tenis ATR</div><div class="brand-sb">Tour Corrientes</div></div>
  </div>
  <div style="display:flex;align-items:center;gap:10px">
    <div class="sync"><div class="sync-dot" id="syncDot"></div><span id="syncTxt">Conectando</span></div>
    <span class="hdr-yr">2026</span>
  </div>
</div></header>

<main class="main" id="app" style="opacity:0;transition:opacity .4s">

<div class="page active" id="pg-ranking">
  <div class="slbl">Ranking</div>
  <div class="ctabs" id="rTabs"></div>
  <div class="ctabs" id="rGrpTabs" style="margin-top:-10px"></div>
  <div id="rTbl"></div>
</div>

<div class="page" id="pg-cuadros">
  <div class="slbl">Cuadros por Categoría</div>
  <div class="ctabs" id="cTabs"></div>
  <div class="ctabs" id="cGrpTabs" style="margin-top:-10px"></div>
  <div id="cGrid"></div>
</div>

<div class="page" id="pg-resultados">
  <div class="slbl">Resultados</div>
  <div id="resList"></div>
</div>

<div class="page" id="pg-jugadores">
  <div class="af">
    <div class="af-t">➕ Agregar Pareja</div>
    <div class="fr">
      <input class="fi" id="jN" placeholder="Apellido 1"/>
      <input class="fi" id="jA" placeholder="Apellido 2"/>
    </div>
    <div class="fr">
      <select class="fs" id="jC">
        <option value="">Categoría...</option>
        <option value="signature">Signature</option><option value="oro">Oro</option>
        <option value="plata">Plata</option><option value="bronce">Bronce</option>
        <option value="madera">Madera</option><option value="mujeres">Mujeres</option>
      </select>
      <select class="fs" id="jG">
        <option value="">Grupo...</option>
        <option value="A">A</option><option value="B">B</option>
        <option value="C">C</option><option value="D">D</option>
      </select>
    </div>
    <div class="fr">
      <button class="fb" onclick="addJug()" style="flex:1">Agregar</button>
      <button onclick="quickAddJug()" title="Agregar otra (mantiene cat y grupo)"
        style="width:48px;border-radius:var(--rs);border:1px solid var(--acc);background:var(--acc-d);color:var(--acc);cursor:pointer;font-size:1.3rem;font-weight:700;flex-shrink:0">+</button>
    </div>
  </div>
  <div id="jugInfo" style="display:none;margin-bottom:16px"></div>
  <div class="slbl">Parejas Inscriptas</div>
  <div id="jugList"></div>
</div>

</main>

<button class="fab" id="fab" onclick="openResMod()">+</button>

<!-- Modal: Cargar Resultado -->
<div class="mbg" id="mRes" onclick="if(event.target===this)clMod('mRes')"><div class="mdl">
  <div class="mh"><span class="mt">Cargar Resultado</span><button class="mx" onclick="clMod('mRes')">✕</button></div>
  <div class="fr">
    <select class="fs" id="rCat" onchange="rPickCat()"><option value="">Categoría...</option></select>
    <select class="fs" id="rGrp" onchange="rPickGrp()">
      <option value="">Grupo...</option>
      <option value="A">A</option><option value="B">B</option>
      <option value="C">C</option><option value="D">D</option>
      <option value="_all">Sin filtro</option>
    </select>
  </div>
  <div class="fr">
    <select class="fs" id="rP1"><option value="">Pareja 1...</option></select>
    <span style="color:var(--tm);align-self:center;font-weight:700;flex-shrink:0">VS</span>
    <select class="fs" id="rP2"><option value="">Pareja 2...</option></select>
  </div>
  <div class="fr"><input class="fi" id="rSc" placeholder="Score (ej: 6-3 6-4)"/></div>
  <div class="fr">
    <select class="fs" id="rW">
      <option value="">Ganador...</option>
      <option value="1">Pareja 1</option><option value="2">Pareja 2</option>
    </select>
  </div>
  <div class="fr"><input type="date" class="fi" id="rDt"/></div>
  <button class="fb" id="btnSaveRes" onclick="saveRes()">Guardar Resultado</button>
</div></div>

<!-- Modal: Editar Resultado -->
<div class="mbg" id="mEditR" onclick="if(event.target===this)clMod('mEditR')"><div class="mdl">
  <div class="mh"><span class="mt">Editar Resultado</span><button class="mx" onclick="clMod('mEditR')">✕</button></div>
  <div style="font-size:.85rem;color:var(--t2);margin-bottom:14px;text-align:center;font-weight:600" id="eRInfo"></div>
  <div class="fr"><input class="fi" id="eRSc" placeholder="Score (ej: 6-3 6-4)"/></div>
  <div class="fr">
    <select class="fs" id="eRW">
      <option value="">Ganador...</option>
      <option value="1">Pareja 1</option><option value="2">Pareja 2</option>
    </select>
  </div>
  <div class="fr"><input type="date" class="fi" id="eRDt"/></div>
  <button class="fb" onclick="saveEditR()">Guardar Cambios</button>
</div></div>

<!-- Modal: Editar Pareja -->
<div class="mbg" id="mEditJ" onclick="if(event.target===this)clMod('mEditJ')"><div class="mdl">
  <div class="mh"><span class="mt">Editar Pareja</span><button class="mx" onclick="clMod('mEditJ')">✕</button></div>
  <div class="fr">
    <input class="fi" id="ejN" placeholder="Apellido 1"/>
    <input class="fi" id="ejA" placeholder="Apellido 2"/>
  </div>
  <div class="fr">
    <select class="fs" id="ejC">
      <option value="">Categoría...</option>
      <option value="signature">Signature</option><option value="oro">Oro</option>
      <option value="plata">Plata</option><option value="bronce">Bronce</option>
      <option value="madera">Madera</option><option value="mujeres">Mujeres</option>
    </select>
  </div>
  <div class="fr">
    <select class="fs" id="ejG">
      <option value="">Sin grupo</option>
      <option value="A">Grupo A</option><option value="B">Grupo B</option>
