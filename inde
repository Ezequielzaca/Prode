function buildGrid(players,title){
  if(!players.length)return'';
  var rM={};
  results.filter(function(r){return r.cat===selCat}).forEach(function(r){
    rM[r.p1id+'_'+r.p2id]=r;
    rM[r.p2id+'_'+r.p1id]={score:r.score,winner:r.winner,flip:true};
  });
  var h='<div class="slbl" style="margin-top:16px;margin-bottom:8px">'+title+'</div><div class="gw"><table class="gt"><thead><tr><th></th><th class="cn">#</th>';
  players.forEach(function(_,i){h+='<th class="cn">'+(i+1)+'</th>'});
  h+='</tr></thead><tbody>';
  players.forEach(function(p,i){
    h+='<tr><td class="rn">'+pnm(p)+'</td><td class="cn">'+(i+1)+'</td>';
    players.forEach(function(q,j){
      if(i===j){h+='<td class="self">—</td>';return}
      var r=rM[p.id+'_'+q.id];
      if(r){var w=r.flip?r.winner===2:r.winner===1;h+='<td class="'+(w?'win':'loss')+'">'+r.score+'</td>'}
      else h+='<td></td>';
    });
    h+='</tr>';
  });
  return h+'</tbody></table></div>';
}
function rGrid(){
  var el=document.getElementById('cGrid');
  if(!selCat){el.innerHTML='<div class="es"><div class="es-i">📋</div><div class="es-t">Seleccioná una categoría</div></div>';return}
  var pl=parts.filter(function(p){return p.cat===selCat});
  if(!pl.length){el.innerHTML='<div class="es"><div class="es-i">📋</div><div class="es-t">Sin parejas en '+CL[selCat]+'</div></div>';return}
  var html='';
  if(selGrp===null){
    ['A','B','C','D'].forEach(function(g){var gpl=pl.filter(function(p){return p.grupo===g}).sort(srt);if(gpl.length)html+=buildGrid(gpl,'Grupo '+g+' — '+CL[selCat])});
    var noG=pl.filter(function(p){return!p.grupo||!['A','B','C','D'].includes(p.grupo)}).sort(srt);
    if(noG.length)html+=buildGrid(noG,'Sin Grupo — '+CL[selCat]);
  }else{
    var gpl=pl.filter(function(p){return p.grupo===selGrp}).sort(srt);
    html=gpl.length?buildGrid(gpl,'Grupo '+selGrp+' — '+CL[selCat]):'<div class="es"><div class="es-i">📋</div><div class="es-t">Sin parejas en Grupo '+selGrp+'</div></div>';
  }
  el.innerHTML=html||'<div class="es"><div class="es-i">📋</div><div class="es-t">Sin grupos asignados</div></div>';
}

