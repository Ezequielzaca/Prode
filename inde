  if(!cat||!p1id||!p2id||!score||!winner||!fecha){toast('⚠ Completá todos los campos');return}
  if(p1id===p2id){toast('⚠ Las parejas deben ser distintas');return}
  var p1=parts.find(function(p){return p.id===p1id}),p2=parts.find(function(p){return p.id===p2id});
  if(!p1||!p2)return;
  var nuevo={id:uid(),fecha:fecha,cat:cat,grupo:grp==='_all'?'':grp,p1id:p1id,p2id:p2id,p1:pnm(p1),p2:pnm(p2),score:score,winner:winner};
  var btn=document.getElementById('btnSaveRes');btn.disabled=true;btn.textContent='Guardando...';
  db.ref('resultados').set(results.concat([nuevo]),function(err){
    btn.disabled=false;btn.textContent='Guardar Resultado';
    if(err){toast('⚠ Error de conexión');return}
    clMod('mRes');toast('✓ Resultado guardado');
  });
