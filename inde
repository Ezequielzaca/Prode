    gt.appendChild(d);
  });
}
function togRCat(cat){rkCat=(rkCat===cat)?null:cat;rkGrp=null;rRTabs();rRPts()}

function calcStats(cat,grp){
  var pl=parts.filter(function(p){return p.cat===cat&&(grp===null||p.grupo===grp)});
  var st={};
  pl.forEach(function(p){st[p.id]={id:p.id,nm:pnm(p),cat:p.cat,grp:p.grupo||'',pj:0,pg:0,pp:0,pts:0,sg:0,sp:0,gg:0,gp:0}});
  results.filter(function(r){return r.cat===cat}).forEach(function(r){
    if(!st[r.p1id]&&!st[r.p2id])return;
    var sc=parseScore(r.score);
    var wid=r.winner===1?r.p1id:r.p2id,lid=r.winner===1?r.p2id:r.p1id;
    var wS=r.winner===1?sc.s1:sc.s2,lS=r.winner===1?sc.s2:sc.s1;
    var wG=r.winner===1?sc.g1:sc.g2,lG=r.winner===1?sc.g2:sc.g1;
    if(st[wid]){st[wid].pj++;st[wid].pg++;st[wid].pts++;st[wid].sg+=wS;st[wid].sp+=lS;st[wid].gg+=wG;st[wid].gp+=lG}
    if(st[lid]){st[lid].pj++;st[lid].pp++;st[lid].pts--;st[lid].sg+=lS;st[lid].sp+=wS;st[lid].gg+=lG;st[lid].gp+=wG}
  });
  var arr=Object.values(st);
  arr.forEach(function(s){s.sd=s.sg-s.sp;s.gd=s.gg-s.gp});
  arr.sort(function(a,b){return b.pts-a.pts||b.sd-a.sd||b.gd-a.gd});
  var mx=Math.max.apply(null,arr.map(function(x){return Math.abs(x.sd)}).concat([1]));
  var mg=Math.max.apply(null,arr.map(function(x){return Math.abs(x.gd)}).concat([1]));
  arr.forEach(function(s,i){
    s.pos=i+1;
    s.rat=s.pj===0?50:Math.round(Math.max(1,Math.min(100,((s.pg/s.pj)*.6+((s.sd/mx+1)/2)*.2+((s.gd/mg+1)/2)*.2)*100)));
  });
  return arr;
}

function rRPts(){
  var el=document.getElementById('rTbl');
  if(!rkCat){el.innerHTML='<div class="es"><div class="es-i">🏆</div><div class="es-t">Seleccioná una categoría</div></div>';return}
  var arr=calcStats(rkCat,rkGrp);window._pd=arr;
  if(!arr.length){el.innerHTML='<div class="es"><div class="es-i">👥</div><div class="es-t">Sin parejas'+(rkGrp?' en Grupo '+rkGrp:'')+'</div></div>';return}
  var showGrp=rkGrp===null&&arr.some(function(s){return s.grp});
  var title=(rkGrp===null?'General':'Grupo '+rkGrp)+' — '+CL[rkCat];
  var h='<div style="font-weight:600;font-size:.85rem;margin-bottom:12px;text-align:center;color:var(--t2)">'+title+'</div>';
  h+='<div class="pw"><table class="pt"><thead><tr><th>#</th><th class="pn">Pareja</th>';
  if(showGrp)h+='<th>Grp</th>';
  h+='<th>PJ</th><th>PG</th><th>PP</th><th>Pts</th><th class="sep">SG</th><th>SP</th><th>Dif</th><th class="sep">GG</th><th>GP</th><th>Dif</th></tr></thead><tbody>';
  arr.forEach(function(s,i){
    var pC=i===0?'p1c':i===1?'p2c':i===2?'p3c':'';
    h+='<tr><td class="pp '+pC+'">'+s.pos+'</td><td class="pn" onclick="openCard('+i+')">'+s.nm+'</td>';
    if(showGrp)h+='<td style="font-size:.6rem;color:var(--tm);font-weight:600">'+(s.grp||'—')+'</td>';
    h+='<td>'+s.pj+'</td><td class="pos">'+s.pg+'</td><td class="neg">'+s.pp+'</td>';
    h+='<td class="pv '+vc(s.pts)+'">'+vs(s.pts)+'</td>';
    h+='<td class="sep">'+s.sg+'</td><td>'+s.sp+'</td><td class="'+vc(s.sd)+'">'+vs(s.sd)+'</td>';
    h+='<td class="sep">'+s.gg+'</td><td>'+s.gp+'</td><td class="'+vc(s.gd)+'">'+vs(s.gd)+'</td></tr>';
  });
  h+='</tbody></table></div>';el.innerHTML=h;
}

